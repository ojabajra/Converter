terraform {
  required_version = ">= 1.5"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

# Resolves the current AWS account ID so you don't have to hard-code it.
data "aws_caller_identity" "current" {}
